          '<option value="'+m.id+'"'+(val===m.id?' selected':'')+'>'+esc(m.name)+'</option>'
        ));
        input = '<select data-field="'+f.key+'">' + opts2.join('') + '</select>';
      } else if(f.type === 'textarea'){
        input = '<textarea data-field="'+f.key+'">'+esc(val)+'</textarea>';
