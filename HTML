      '</tr>'
    ).join('');

    return ''+
    '<div class="card">'+
      '<div class="toolbar"><div><h2 style="margin-bottom:2px;">メンバー一覧</h2><div class="desc" style="margin:0;">運営メンバーとスケジュール上の担当割り当てを管理します。</div></div>'+
      '<button class="btn btn-primary" data-action="add-member">＋ メンバーを追加</button></div>'+
      (state.members.length ? '<div class="table-scroll"><table><thead><tr><th>氏名</th><th>役割</th><th>メモ</th><th></th></tr></thead><tbody>'+rows+'</tbody></table></div>'
        : '<div class="empty">メンバーが登録されていません。「＋ メンバーを追加」から登録してください。</div>')+
      '<div class="note"><strong>デスクネッツ連携について：</strong> このアプリからデスクネッツのスケジュールへ自動連携することはできません（外部システムへの直接アクセス権限がないため）。</div>'+
    '</div>';
  }

  function memberFields(){
    return [
      {key:'name', label:'氏名', type:'text'},
      {key:'role', label:'役割・担当領域', type:'text'},
      {key:'note', label:'メモ', type:'text'}
    ];
  }

  // ---------- SCHEDULE ----------
  function scheduleDateLabel(s){
    if(s.endDate && s.endDate !== s.date){
      return fmtDate(s.date) + ' 〜 ' + fmtDate(s.endDate);
    }
    return fmtDate(s.date);
  }

  function renderSchedule(){
    let items = state.schedule.slice().sort((a,b)=>a.date.localeCompare(b.date));
    if(scheduleFilter!=='all') items = items.filter(s=>s.phase===scheduleFilter);

    const rows = items.map(s=>
      '<tr>'+
        '<td>'+esc(s.title)+(s.memo?'<div style="font-size:11.5px; color:var(--ink-faint); margin-top:2px;">'+esc(s.memo)+'</div>':'')+'</td>'+
        '<td><span class="badge '+PHASE_BADGE[s.phase]+'">'+s.phase+'</span></td>'+
        '<td>'+scheduleDateLabel(s)+'</td>'+
        '<td>'+esc(memberName(s.assigneeId))+'</td>'+
        '<td><span class="badge '+STATUS_BADGE[s.status]+'">'+s.status+'</span></td>'+
        '<td class="row-actions">'+
          '<button class="btn btn-sm" data-action="edit-schedule" data-id="'+s.id+'">編集</button> '+
          '<button class="btn btn-sm btn-danger" data-action="delete-schedule" data-id="'+s.id+'">削除</button>'+
        '</td>'+
      '</tr>'
    ).join('');

    return ''+
    '<div class="card">'+
      '<div class="toolbar">'+
        '<div><h2 style="margin-bottom:2px;">スケジュール管理</h2><div class="desc" style="margin:0;">打合せから開催当日、事後対応までのタスクを一元管理します。複数日にわたる場合は終了日も設定できます。</div></div>'+
        '<button class="btn btn-primary" data-action="add-schedule">＋ タスクを追加</button>'+
      '</div>'+
      '<div class="toolbar"><div class="filters">'+
        '<select class="filter-select" data-action="filter-schedule">'+
          '<option value="all"'+(scheduleFilter==='all'?' selected':'')+'>すべてのフェーズ</option>'+
          PHASES.map(p=>'<option value="'+p+'"'+(scheduleFilter===p?' selected':'')+'>'+p+'</option>').join('')+
        '</select>'+
      '</div></div>'+
      (items.length ? '<div class="table-scroll"><table><thead><tr><th>項目</th><th>フェーズ</th><th>期間</th><th>担当</th><th>状況</th><th></th></tr></thead><tbody>'+rows+'</tbody></table></div>'
        : '<div class="empty">該当するタスクがありません。</div>')+
    '</div>';
  }

  function scheduleFields(){
    return [
      {key:'title', label:'項目名', type:'text'},
      {key:'phase', label:'フェーズ', type:'select', options:PHASES},
      {key:'dateRange', label:'期間', type:'date-range', startKey:'date', endKey:'endDate'},
      {key:'assigneeId', label:'担当者', type:'select-member'},
      {key:'status', label:'状況', type:'select', options:STATUS_LIST},
      {key:'memo', label:'メモ', type:'text'}
    ];
  }

  // ---------- BUDGET ----------
  function renderBudget(){
    const rows = state.budget.map(b=>{
      const diff = (Number(b.actual)||0) - (Number(b.budgeted)||0);
      const over = diff > 0;
      return '<tr>'+
        '<td>'+esc(b.category)+(b.memo?'<div style="font-size:11.5px; color:var(--ink-faint); margin-top:2px;">'+esc(b.memo)+'</div>':'')+'</td>'+
        '<td class="num">'+yen(b.budgeted)+'</td>'+
        '<td class="num">'+yen(b.actual)+'</td>'+
        '<td class="num"><span class="badge '+(over?'badge-danger':'badge-teal')+'">'+(over?'+':'')+yen(diff)+'</span></td>'+
        '<td class="row-actions">'+
          '<button class="btn btn-sm" data-action="edit-budget" data-id="'+b.id+'">編集</button> '+
          '<button class="btn btn-sm btn-danger" data-action="delete-budget" data-id="'+b.id+'">削除</button>'+
        '</td>'+
      '</tr>';
    }).join('');

    const totalBudgeted = state.budget.reduce((s,b)=>s+(Number(b.budgeted)||0),0);
    const totalActual = state.budget.reduce((s,b)=>s+(Number(b.actual)||0),0);
    const totalDiff = totalActual - totalBudgeted;

    return ''+
    '<div class="card">'+
      '<div class="toolbar">'+
        '<div><h2 style="margin-bottom:2px;">予算管理</h2><div class="desc" style="margin:0;">費目ごとの予算額と実績額を入力し、差異を自動計算します。</div></div>'+
        '<button class="btn btn-primary" data-action="add-budget">＋ 費目を追加</button>'+
      '</div>'+
      (state.budget.length ? '<div class="table-scroll"><table><thead><tr><th>費目</th><th class="num">予算額</th><th class="num">実績額</th><th class="num">差異</th><th></th></tr></thead><tbody>'+rows+
        '<tr><td style="font-weight:700;">合計</td>'+
        '<td class="num" style="font-weight:700;">'+yen(totalBudgeted)+'</td>'+
        '<td class="num" style="font-weight:700;">'+yen(totalActual)+'</td>'+
        '<td class="num" style="font-weight:700;"><span class="badge '+(totalDiff>0?'badge-danger':'badge-teal')+'">'+(totalDiff>0?'+':'')+yen(totalDiff)+'</span></td><td></td></tr>'+
        '</tbody></table></div>' : '<div class="empty">予算項目が登録されていません。</div>')+
    '</div>';
  }

  function budgetFields(){
    return [
      {key:'category', label:'費目', type:'text'},
      {key:'budgeted', label:'予算額（円）', type:'number', min:0},
      {key:'actual', label:'実績額（円）', type:'number', min:0},
      {key:'memo', label:'メモ', type:'text'}
    ];
  }

  // ---------- SURVEY ----------
  function renderSurvey(){
    const n = state.survey.length;
    const avg = n ? state.survey.reduce((s,r)=>s+(Number(r.satisfaction)||0),0)/n : 0;
    const dist = [1,2,3,4,5].map(v=> state.survey.filter(r=>Number(r.satisfaction)===v).length);
    const maxDist = Math.max(1, ...dist);

    const comments = state.survey.slice().sort((a,b)=> (b.date||'').localeCompare(a.date||'')).map(r=>
      '<div class="comment-item">'+
        '<div class="meta">'+fmtDate(r.date)+' ・ <span class="stars">'+'★'.repeat(Number(r.satisfaction)||0)+'☆'.repeat(5-(Number(r.satisfaction)||0))+'</span></div>'+
        '<div>'+(r.comment ? esc(r.comment) : '<span style="color:var(--ink-faint);">コメントなし</span>')+'</div>'+
      '</div>'
    ).join('');

    return ''+
    '<div class="card">'+
      '<h2>アンケート結果ダッシュボード</h2>'+
      '<p class="desc">回答を入力・貼り付けすると、満足度の分布とコメントを自動集計します。</p>'+
      '<div class="grid-2">'+
        '<div class="metric"><div class="label">平均満足度</div><div class="value">'+(n? avg.toFixed(2):'-')+' <span style="font-size:14px; color:var(--ink-soft); font-family:inherit;">/ 5</span></div><div class="hint">回答数 '+n+' 件</div></div>'+
        '<div class="metric">'+
          '<div class="label">満足度の分布</div>'+
          [5,4,3,2,1].map(v=>{
            const c = dist[v-1];
            const w = Math.round(c/maxDist*100);
            return '<div style="display:flex; align-items:center; gap:8px; margin-top:6px;">'+
              '<span style="font-size:11.5px; width:14px; color:var(--ink-soft);">'+v+'</span>'+
              '<div class="bar-track" style="flex:1;"><div class="bar-fill" style="width:'+w+'%; background:var(--orange);"></div></div>'+
              '<span style="font-size:11.5px; width:22px; text-align:right; color:var(--ink-soft);">'+c+'</span>'+
            '</div>';
          }).join('')+
        '</div>'+
      '</div>'+
    '</div>'+

    '<div class="card">'+
      '<div class="toolbar"><h2 style="margin-bottom:2px;">回答の追加</h2></div>'+
      '<div class="grid-2" style="align-items:start;">'+
        '<div><div class="field"><label>1件ずつ入力</label></div>'+
          '<button class="btn btn-primary" data-action="add-survey">＋ 回答を1件追加</button>'+
        '</div>'+
        '<div>'+
          '<div class="field"><label>まとめて貼り付け（1行＝1件、形式: 満足度,コメント）</label>'+
            '<textarea id="bulkSurvey" placeholder="5,内容が分かりやすかった&#10;4,時間が長かった"></textarea>'+
          '</div>'+
          '<button class="btn" data-action="bulk-survey">まとめて取り込む</button>'+
        '</div>'+
      '</div>'+
      '<div style="margin-top:16px; padding-top:16px; border-top:1.5px dashed var(--border-strong);">'+
        '<div class="field"><label>CSVファイルから取り込む（1列目: 満足度[1-5]、2列目: コメント、3列目: 回答日（任意）／1行目に見出しがあってもOK）</label>'+
          '<input type="file" id="surveyCsvInput" accept=".csv,text/csv">'+
        '</div>'+
        '<button class="btn" data-action="import-survey-csv">CSVを取り込む</button>'+
      '</div>'+
    '</div>'+

    '<div class="card">'+
      '<h2>コメント一覧</h2>'+
      (n ? comments : '<div class="empty">まだ回答がありません。</div>')+
    '</div>';
  }

  function surveyFields(){
    return [
      {key:'satisfaction', label:'総合満足度', type:'select', options:['5','4','3','2','1']},
      {key:'comment', label:'コメント', type:'textarea'},
      {key:'date', label:'回答日', type:'date'}
    ];
  }

  // ---------- ACTIONS ----------
  async function handleAction(action, target){
    if(action==='switch-tab'){ activeTab = target.dataset.tab; render(); return; }
    if(action==='filter-schedule'){ scheduleFilter = target.value; renderTab(); return; }
    if(action==='close-modal'){ closeModal(); return; }

    if(action==='refresh-data'){
      await runApiAction(async ()=>{ await refreshFromApi(); }, '最新のデータを取得しました');
      return;
    }

    if(action==='edit-api-url'){
      openModal({
        title:'API設定（Apps ScriptのウェブアプリURL）',
        fields:[{key:'apiUrl', label:'ウェブアプリのURL', type:'text', required:true}],
        values:{ apiUrl: apiUrl || '' },
        onSubmit: async (v)=>{
          const url = v.apiUrl.trim();
          await setApiUrl(url);
          const ok = await runApiAction(async ()=>{ await refreshFromApi(); }, '接続できました');
          if(ok){ closeModal(); render(); }
        }
      });
      return;
    }

    if(action==='edit-access-code'){
      openModal({
        title:'アクセスコード',
        fields:[{key:'accessCode', label:'合言葉（Apps Script側の ACCESS_CODE と同じもの）', type:'text'}],
        values:{ accessCode: accessCode || '' },
        onSubmit: async (v)=>{
          await setAccessCode(v.accessCode.trim());
          const ok = await runApiAction(async ()=>{ await refreshFromApi(); }, '接続できました');
          if(ok){ closeModal(); render(); }
        }
      });
      return;
    }

    if(action==='edit-event-info'){
      openModal({
        title:'イベント基本情報の編集',
        fields:[{key:'teamName', label:'プロジェクトチーム名', type:'text'},{key:'name', label:'イベント名', type:'text'},{key:'date', label:'開催日', type:'date'}],
        values: state.eventInfo,
        onSubmit: async (v)=>{
          const ok = await runApiAction(async ()=>{
            await apiPost('eventInfo', 'set', {teamName:v.teamName, name:v.name, date:v.date});
          }, '保存しました');
          if(ok){ closeModal(); render(); }
        }
      });
      return;
    }

    if(action==='add-member'){
      openModal({ title:'メンバーを追加', fields:memberFields(), values:{},
        onSubmit: async (v)=>{
          const ok = await runApiAction(async ()=>{ await apiPost('members','add', {id:uid(), ...v}); }, '保存しました');
          if(ok){ closeModal(); renderTab(); }
        } });
      return;
    }
    if(action==='edit-member'){
      const m = state.members.find(x=>x.id===target.dataset.id);
      openModal({ title:'メンバーを編集', fields:memberFields(), values:m,
        onSubmit: async (v)=>{
          const ok = await runApiAction(async ()=>{ await apiPost('members','update', {id:m.id, ...v}); }, '保存しました');
          if(ok){ closeModal(); renderTab(); }
        } });
      return;
    }
    if(action==='delete-member'){
      if(confirm('このメンバーを削除しますか？')){
        await runApiAction(async ()=>{ await apiPost('members','delete', {id:target.dataset.id}); }, '削除しました');
      }
      return;
    }

    if(action==='add-schedule'){
      openModal({ title:'タスクを追加', fields:scheduleFields(), values:{phase:'企画', status:'未着手', date:todayStr()},
        onSubmit: async (v)=>{
          const ok = await runApiAction(async ()=>{ await apiPost('schedule','add', {id:uid(), ...v}); }, '保存しました');
          if(ok){ closeModal(); render(); }
        } });
      return;
    }
    if(action==='edit-schedule'){
      const s = state.schedule.find(x=>x.id===target.dataset.id);
      openModal({ title:'タスクを編集', fields:scheduleFields(), values:s,
        onSubmit: async (v)=>{
          const ok = await runApiAction(async ()=>{ await apiPost('schedule','update', {id:s.id, ...v}); }, '保存しました');
          if(ok){ closeModal(); render(); }
        } });
      return;
    }
    if(action==='delete-schedule'){
      if(confirm('このタスクを削除しますか？')){
        await runApiAction(async ()=>{ await apiPost('schedule','delete', {id:target.dataset.id}); }, '削除しました');
      }
      return;
    }

    if(action==='add-budget'){
      openModal({ title:'費目を追加', fields:budgetFields(), values:{budgeted:0, actual:0},
        onSubmit: async (v)=>{
          const payload = {id:uid(), category:v.category, budgeted:Number(v.budgeted)||0, actual:Number(v.actual)||0, memo:v.memo};
          const ok = await runApiAction(async ()=>{ await apiPost('budget','add', payload); }, '保存しました');
          if(ok){ closeModal(); render(); }
        } });
      return;
    }
    if(action==='edit-budget'){
      const b = state.budget.find(x=>x.id===target.dataset.id);
      openModal({ title:'費目を編集', fields:budgetFields(), values:b,
        onSubmit: async (v)=>{
          const payload = {id:b.id, category:v.category, budgeted:Number(v.budgeted)||0, actual:Number(v.actual)||0, memo:v.memo};
          const ok = await runApiAction(async ()=>{ await apiPost('budget','update', payload); }, '保存しました');
          if(ok){ closeModal(); render(); }
        } });
      return;
    }
    if(action==='delete-budget'){
      if(confirm('この費目を削除しますか？')){
        await runApiAction(async ()=>{ await apiPost('budget','delete', {id:target.dataset.id}); }, '削除しました');
      }
      return;
    }

    if(action==='add-survey'){
      openModal({ title:'アンケート回答を追加', fields:surveyFields(), values:{satisfaction:'5', date:todayStr()},
        onSubmit: async (v)=>{
          const payload = {id:uid(), satisfaction:Number(v.satisfaction), comment:v.comment, date:v.date||todayStr()};
          const ok = await runApiAction(async ()=>{ await apiPost('survey','add', payload); }, '保存しました');
          if(ok){ closeModal(); renderTab(); }
        } });
      return;
    }
    if(action==='bulk-survey'){
      const raw = document.getElementById('bulkSurvey').value;
      const lines = raw.split('\n').map(l=>l.trim()).filter(Boolean);
      if(!lines.length) return;
      const items = [];
      lines.forEach(line=>{
        const idx = line.indexOf(',');
        let sat, comment;
        if(idx===-1){ sat = line.trim(); comment=''; } else { sat = line.slice(0,idx).trim(); comment = line.slice(idx+1).trim(); }
        sat = Math.max(1, Math.min(5, Math.round(Number(sat))||0));
        if(sat>=1 && sat<=5){ items.push({id:uid(), satisfaction:sat, comment:comment, date:todayStr()}); }
      });
      if(!items.length) return;
      const ok = await runApiAction(async ()=>{ await apiPost('survey','bulkAdd', items); }, '取り込みました');
      if(ok){ document.getElementById('bulkSurvey').value = ''; }
      renderTab();
      return;
    }
    if(action==='import-survey-csv'){
      const fileInput = document.getElementById('surveyCsvInput');
      const file = fileInput && fileInput.files && fileInput.files[0];
      if(!file){ alert('CSVファイルを選択してください。'); return; }
      let items;
      try{
        const text = await readCsvFileAsText(file);
        items = parseSurveyCsvRows(text);
      }catch(err){
        console.error('csv read/parse failed', err);
        alert('CSVの読み込みに失敗しました。\n(' + err.message + ')');
        return;
      }
      if(!items.length){ alert('取り込める行が見つかりませんでした。1列目が1〜5の数字になっているかご確認ください。'); return; }
      const ok = await runApiAction(async ()=>{ await apiPost('survey','bulkAdd', items); }, items.length + '件取り込みました');
      if(ok){ fileInput.value = ''; }
      renderTab();
      return;
    }
    if(action==='export-report'){
      try{ exportWordReport(); }
      catch(err){ console.error('report export failed', err); alert('報告書の作成に失敗しました。\n(' + err.message + ')'); }
      return;
    }
  }

  // Excel(日本語版)で保存したCSVはShift_JIS(Windows-31J)であることが多いため、
  // UTF-8で読んで文字化けしていそうな場合はShift_JISとして読み直す。
  async function readCsvFileAsText(file){
    const buf = await file.arrayBuffer();
    let text = new TextDecoder('utf-8').decode(buf);
    const brokenCount = (text.match(/\uFFFD/g) || []).length;
    if(brokenCount > 2){
      try{ text = new TextDecoder('shift-jis').decode(buf); }catch(e){ /* keep utf-8 result */ }
    }
    return text;
  }

  function parseSurveyCsvRows(text){
    const parsed = Papa.parse(text, { skipEmptyLines:true });
    const items = [];
    (parsed.data || []).forEach(row=>{
      if(!row || !row.length) return;
      const first = String(row[0]).trim();
      if(!/^\d+(\.\d+)?$/.test(first)) return; // skip header row / non-numeric rows
      const sat = Math.max(1, Math.min(5, Math.round(Number(first)) || 0));
      const comment = row[1] !== undefined ? String(row[1]).trim() : '';
      let date = todayStr();
      if(row[2]){
        const m = String(row[2]).trim().match(/^(\d{4}-\d{2}-\d{2})/);
        if(m) date = m[1];
      }
      items.push({id:uid(), satisfaction:sat, comment:comment, date:date});
    });
    return items;
  }

  document.addEventListener('click', function(e){
    const target = e.target.closest('[data-action]');
    if(!target) return;
    handleAction(target.dataset.action, target);
  });
  document.addEventListener('change', function(e){
    const target = e.target.closest('[data-action]');
    if(!target) return;
    handleAction(target.dataset.action, target);
  });

  (async function init(){
    state = emptyState();
    apiUrl = await getApiUrl();
    accessCode = await getAccessCode();
    if(apiUrl){
      await runApiAction(async ()=>{ await refreshFromApi(); });
    } else {
      render();
    }
    // near-real-time sync: poll for changes made by teammates, unless a modal is currently open
    setInterval(async ()=>{
      if(modalOpen || !apiUrl) return;
      try{ await refreshFromApi(); renderShell(); renderTab(); }catch(e){ /* ignore transient errors */ }
    }, 20000);
  })();
})();
</script>
</body>
