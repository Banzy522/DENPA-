    const modalEl = root.querySelector('.modal');
    const formEl = document.getElementById('modalForm');
    const cancelBtn = document.getElementById('modalCancelBtn');

    modalEl.addEventListener('click', function(e){ e.stopPropagation(); });
    overlayEl.addEventListener('click', function(e){ if(e.target === overlayEl){ closeModal(); } });
    cancelBtn.addEventListener('click', function(){ closeModal(); });

    root.querySelectorAll('.cal-mount').forEach(mount=>{
      const startKey = mount.dataset.startKey;
      const endKey = mount.dataset.endKey;
      const startInput = formEl.querySelector('[data-field="'+startKey+'"]');
      const endInput = formEl.querySelector('[data-field="'+endKey+'"]');
      createDateRangePicker(mount, startInput.value, endInput.value, function(start, end){
        startInput.value = start;
        endInput.value = end;
      });
    });

    formEl.addEventListener('submit', async function(e){
      e.preventDefault();
      try{
        const values = {};
        opts.fields.forEach(f=>{
          if(f.type === 'date-range'){
            const startEl = formEl.querySelector('[data-field="'+f.startKey+'"]');
            const endEl = formEl.querySelector('[data-field="'+f.endKey+'"]');
            values[f.startKey] = startEl ? startEl.value : '';
            values[f.endKey] = endEl ? endEl.value : '';
          } else {
            const el = formEl.querySelector('[data-field="'+f.key+'"]');
            values[f.key] = el ? el.value : '';
          }
        });
        await opts.onSubmit(values);
      }catch(err){
        console.error('modal submit failed', err);
        alert('保存中にエラーが発生しました。もう一度お試しください。');
      }
    });
  }

