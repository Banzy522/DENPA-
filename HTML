<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DENPA - イベント運営管理アプリ</title>
<link rel="manifest" href="data:application/manifest+json;base64,">
<meta name="theme-color" content="#F0347A">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="DENPA">
<link rel="apple-touch-icon" href="data:image/png;base64,">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Kosugi+Maru&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#FFF7EA;
    --paper:#FFFFFF;
    --border:#F0E4F2;
    --border-strong:#E4CFE8;
    --ink:#2B2140;
    --ink-soft:#6E5F8A;
    --ink-faint:#A99CC2;
    --teal:#0E9E86;
    --teal-bg:#DEF7F0;
    --orange:#E88A00;
    --orange-bg:#FFEDCC;
    --blue:#2F7BEE;
    --blue-bg:#E1EDFF;
    --purple:#8348D6;
    --purple-bg:#F0E6FB;
    --pink:#F0347A;
    --pink-bg:#FEE3ED;
    --danger:#E8394C;
    --danger-bg:#FDE3E6;
    --radius:20px;
    --shadow: 0 2px 0 rgba(43,33,64,0.05), 0 10px 24px rgba(131,72,214,0.10);
  }
  *{ box-sizing:border-box; }
  html,body{ margin:0; padding:0; }
  body{
    background-color:var(--bg);
    background-image:
      radial-gradient(circle, #F0347A33 0 5px, transparent 6px),
      radial-gradient(circle, #2F7BEE33 0 4px, transparent 5px),
      radial-gradient(circle, #E88A0033 0 5px, transparent 6px),
      radial-gradient(circle, #0E9E8633 0 4px, transparent 5px),
      radial-gradient(circle, #8348D633 0 5px, transparent 6px);
    background-repeat:no-repeat;
    background-position: 6% 8%, 92% 14%, 12% 82%, 88% 78%, 50% 4%;
    background-attachment:fixed;
    color:var(--ink);
    font-family:'Zen Maru Gothic','Noto Sans JP',sans-serif;
    line-height:1.6;
    padding:28px 20px 80px;
  }
  h1,h2,h3, .display{ font-family:'Kosugi Maru', sans-serif; font-weight:400; letter-spacing:.01em; }
  #app{ max-width:1080px; margin:0 auto; position:relative; }

  .topbar{
    position:relative;
    display:flex; align-items:flex-end; justify-content:space-between; gap:16px;
    background:var(--paper); border:2.5px solid var(--ink); border-radius:24px;
    padding:24px 28px; box-shadow:var(--shadow); margin-bottom:26px; flex-wrap:wrap;
    overflow:visible;
  }
  .sync-banner{ background:var(--danger-bg); border:2px dashed var(--danger); color:var(--danger); border-radius:14px; padding:10px 16px; font-size:12.5px; font-weight:700; margin-bottom:18px; }
  .sync-banner.info{ background:var(--blue-bg); border-color:var(--blue); color:var(--blue); }
  .sync-banner.success{ background:var(--teal-bg); border-color:var(--teal); color:var(--teal); border-style:solid; }

  .brandmark{ display:flex; align-items:center; gap:8px; margin-bottom:10px; }
  .brand-name{ font-family:'Kosugi Maru',sans-serif; font-size:20px; letter-spacing:.08em; color:var(--ink); }
  .eyebrow{
    display:inline-block; font-family:'Kosugi Maru',sans-serif; font-size:11px; letter-spacing:.14em;
    color:#fff; background:var(--pink); font-weight:400; text-transform:uppercase;
    padding:4px 12px; border-radius:20px; transform:rotate(-3deg); box-shadow:0 2px 0 rgba(43,33,64,0.15);
  }
  .topbar h1{ font-size:28px; margin:8px 0 2px; color:var(--ink); }
  .topbar .sub{ font-size:13px; color:var(--ink-soft); font-weight:700; }
  .btn{
    appearance:none; border:2px solid var(--ink); background:var(--paper); color:var(--ink);
    border-radius:999px; padding:9px 18px; font-size:13.5px; font-weight:700; cursor:pointer;
    font-family:inherit; transition:transform .1s, box-shadow .1s; box-shadow:0 3px 0 var(--ink);
  }
  .btn:hover{ transform:translateY(-1px); }
  .btn:active{ transform:translateY(2px); box-shadow:0 1px 0 var(--ink); }
  .btn-primary{ background:var(--pink); color:#fff; border-color:var(--pink); box-shadow:0 3px 0 #B01D57; }
  .btn-primary:active{ box-shadow:0 1px 0 #B01D57; }
  .btn-danger{ color:var(--danger); border-color:var(--danger); box-shadow:0 3px 0 var(--danger); }
  .btn-danger:hover{ background:var(--danger-bg); }
  .btn-sm{ padding:5px 12px; font-size:12px; box-shadow:0 2px 0 var(--ink); }
  .btn-sm:active{ box-shadow:0 0px 0 var(--ink); }
  .btn-ghost{ border-color:transparent; background:transparent; box-shadow:none; }
  .btn-ghost:hover{ background:#F3ECF8; }

  .tabs{ display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap; }
  .tab-btn{
    font-family:'Kosugi Maru',sans-serif; border:2px solid var(--ink); background:var(--paper); color:var(--ink);
    padding:10px 20px; border-radius:999px; font-size:14px; font-weight:400; cursor:pointer;
    transition:transform .1s;
  }
  .tab-btn.active{ background:var(--ink); color:#fff; border-color:var(--ink); }
  .tab-btn:hover{ transform:translateY(-2px) rotate(-1deg); }

  .card{ position:relative; background:var(--paper); border:2px solid var(--ink); border-radius:var(--radius); padding:24px 26px; box-shadow:var(--shadow); margin-bottom:18px; }
  .card:nth-of-type(4n+1){ border-top-color:var(--pink); border-top-width:5px; }
  .card:nth-of-type(4n+2){ border-top-color:var(--blue); border-top-width:5px; }
  .card:nth-of-type(4n+3){ border-top-color:var(--orange); border-top-width:5px; }
  .card:nth-of-type(4n+4){ border-top-color:var(--teal); border-top-width:5px; }
  .card h2{ font-size:19px; margin:0 0 4px; }
  .card .desc{ font-size:12.5px; color:var(--ink-soft); margin:0 0 16px; font-weight:500; }

  .grid-4{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
  .grid-2{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  @media(max-width:820px){ .grid-4{ grid-template-columns:repeat(2,1fr);} .grid-2{grid-template-columns:1fr;} }
  @media(max-width:480px){
    body{ padding:16px 10px 70px; }
    .topbar{ padding:18px 18px; }
    .modal{ padding:20px 18px; }
    .card{ padding:18px 16px; }
    .phase-track{ flex-wrap:wrap; }
    .phase-chip{ min-width:calc(50% - 8px); }
    .field input, .field select, .field textarea{ font-size:16px; }
    .modal-actions{ flex-direction:column-reverse; }
    .modal-actions .btn{ width:100%; text-align:center; }
  }

  .metric{ background:#FBF6FF; border:2px solid var(--border); border-radius:14px; padding:16px 18px; }
  .metric:nth-of-type(4n+1){ background:var(--pink-bg); border-color:#F7B8CF; }
  .metric:nth-of-type(4n+2){ background:var(--orange-bg); border-color:#F6CE8A; }
  .metric:nth-of-type(4n+3){ background:var(--teal-bg); border-color:#9FDFCE; }
  .metric:nth-of-type(4n+4){ background:var(--blue-bg); border-color:#AECBFB; }
  .metric .label{ font-size:12px; color:var(--ink-soft); font-weight:700; }
  .metric .value{ font-family:'Kosugi Maru',sans-serif; font-size:27px; font-weight:400; margin-top:4px; }
  .metric .value.small{ font-size:20px; }
  .metric .hint{ font-size:11.5px; color:var(--ink-faint); margin-top:3px; font-weight:500; }

  .ring-wrap{ display:flex; align-items:center; gap:22px; flex-wrap:wrap; }
  .ring-num{ font-family:'Kosugi Maru',sans-serif; font-size:34px; font-weight:400; fill:var(--ink); }
  .ring-lbl{ font-size:11px; fill:var(--ink-soft); font-weight:700; }

  .phase-track{ display:flex; gap:8px; margin-top:6px; }
  .phase-chip{ flex:1; text-align:center; padding:9px 4px; border-radius:12px; font-size:12px; font-weight:700; }

  table{ width:100%; border-collapse:collapse; font-size:13.5px; }
  .table-scroll{ overflow-x:auto; -webkit-overflow-scrolling:touch; margin:0 -4px; }
  .table-scroll table{ min-width:480px; }
  th{ text-align:left; font-size:11.5px; color:var(--ink-soft); font-weight:700; padding:6px 10px; border-bottom:2px dashed var(--border-strong); }
  td{ padding:9px 10px; border-bottom:1.5px dashed var(--border); vertical-align:middle; }
  tr:last-child td{ border-bottom:none; }
  tr:hover td{ background:#FBF6FF; }
  .num{ text-align:right; font-variant-numeric:tabular-nums; }
  .row-actions{ white-space:nowrap; }

  .badge{ display:inline-block; padding:4px 12px; border-radius:20px; font-size:11.5px; font-weight:700; transform:rotate(-1deg); }
  .badge-teal{ background:var(--teal-bg); color:var(--teal); }
  .badge-orange{ background:var(--orange-bg); color:var(--orange); }
  .badge-blue{ background:var(--blue-bg); color:var(--blue); }
  .badge-purple{ background:var(--purple-bg); color:var(--purple); }
  .badge-gray{ background:#EDE6F2; color:var(--ink-soft); }
  .badge-danger{ background:var(--danger-bg); color:var(--danger); }

  .empty{ text-align:center; padding:30px 10px; color:var(--ink-faint); font-size:13.5px; font-weight:700; }

  .modal-overlay{ position:absolute; inset:0; min-height:100%; background:rgba(43,33,64,.5); display:flex; align-items:flex-start; justify-content:center; z-index:50; padding:40px 20px; }
  .modal{ background:var(--paper); border:2.5px solid var(--ink); border-radius:22px; padding:24px 26px; width:100%; max-width:440px; max-height:88vh; overflow-y:auto; box-shadow:0 12px 0 rgba(43,33,64,0.12); }
  .modal h3{ font-size:19px; margin:0 0 16px; }
  .field{ margin-bottom:13px; }
  .field label{ display:block; font-size:12px; font-weight:700; color:var(--ink-soft); margin-bottom:5px; }
  .field input, .field select, .field textarea{
    width:100%; border:2px solid var(--border-strong); border-radius:12px; padding:8px 12px;
    font-family:inherit; font-size:13.5px; color:var(--ink); background:#fff;
  }
  .field input:focus, .field select:focus, .field textarea:focus{ outline:none; border-color:var(--pink); }
  .field textarea{ resize:vertical; min-height:56px; }
  .modal-actions{ display:flex; justify-content:flex-end; gap:8px; margin-top:18px; }

  .toolbar{ display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; gap:10px; flex-wrap:wrap; }
  .toolbar .filters{ display:flex; gap:8px; flex-wrap:wrap; }
  select.filter-select{ border:2px solid var(--border-strong); border-radius:999px; padding:7px 14px; font-family:inherit; font-size:13px; background:#fff; font-weight:700; }

  .bar-track{ height:10px; background:#F0E9F5; border-radius:6px; overflow:hidden; border:1.5px solid var(--border-strong); }
  .bar-fill{ height:100%; border-radius:6px; }

  .note{ font-size:12px; color:var(--ink-soft); background:var(--purple-bg); border:1.5px dashed #C9A8ED; border-radius:14px; padding:12px 14px; margin-top:14px; font-weight:500; }
  .note strong{ color:var(--purple); }

  .stars{ color:var(--orange); letter-spacing:1px; }
  .comment-item{ border-bottom:1.5px dashed var(--border-strong); padding:10px 2px; }
  .comment-item:last-child{ border-bottom:none; }
  .comment-item .meta{ font-size:11.5px; color:var(--ink-faint); margin-bottom:3px; font-weight:700; }

  textarea#bulkSurvey{ width:100%; min-height:80px; border:2px solid var(--border-strong); border-radius:12px; padding:10px; font-family:inherit; font-size:13px; }

  .cal-widget{ border:2px solid var(--border-strong); border-radius:14px; padding:10px 12px; user-select:none; }
  .cal-header{ display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; }
  .cal-header .btn{ padding:3px 10px; }
  .cal-grid{ display:grid; grid-template-columns:repeat(7,1fr); gap:2px; text-align:center; }
  .cal-dow{ font-size:11px; color:var(--ink-soft); font-weight:700; padding:4px 0 6px; }
  .cal-day{ position:relative; border:none; background:transparent; padding:8px 0; font-size:13px;
    cursor:pointer; border-radius:8px; font-family:inherit; color:var(--ink); touch-action:none; }
  .cal-day.other-month{ color:var(--ink-faint); opacity:.45; }
  .cal-day.today{ font-weight:800; box-shadow:inset 0 0 0 1.5px var(--ink); }
  .cal-day.in-range{ background:var(--purple-bg); border-radius:0; }
  .cal-day.range-start{ background:var(--purple); color:#fff; border-radius:8px 0 0 8px; font-weight:700; }
  .cal-day.range-end{ background:var(--purple); color:#fff; border-radius:0 8px 8px 0; font-weight:700; }
  .cal-day.range-single{ background:var(--purple); color:#fff; border-radius:8px; font-weight:700; }
  .cal-summary{ margin-top:8px; font-size:12.5px; color:var(--ink); font-weight:700; text-align:center; }
  .cal-hint{ display:block; font-size:10.5px; color:var(--ink-faint); font-weight:500; margin-top:2px; }
</style>
</head>
<body>
<div id="app">
  <div class="topbar">
    <div>
      <div class="brandmark">
        <svg width="26" height="26" viewBox="0 0 26 26" aria-hidden="true">
          <circle cx="6" cy="20" r="2.6" fill="#F0347A"/>
          <path d="M11 20 A8 8 0 0 0 11 6" fill="none" stroke="#2F7BEE" stroke-width="2.6" stroke-linecap="round"/>
          <path d="M16 20 A13 13 0 0 0 16 1" fill="none" stroke="#E88A00" stroke-width="2.6" stroke-linecap="round"/>
        </svg>
        <span class="brand-name" id="teamNameDisplay">DENPA</span>
      </div>
      <div class="eyebrow">★ Event Ops ★</div>
      <h1 id="eventNameDisplay">読み込み中...</h1>
      <div class="sub" id="eventDateDisplay"></div>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <button class="btn" data-action="refresh-data" title="スプレッドシートの最新データを取得">更新</button>
      <button class="btn" data-action="edit-event-info">基本情報を編集</button>
      <button class="btn" data-action="edit-access-code">アクセスコード</button>
      <button class="btn" data-action="edit-api-url">API設定</button>
    </div>
  </div>
  <div id="syncBanner"></div>

  <div class="tabs" id="tabs"></div>
  <div id="tabContent"></div>
</div>
<div id="modalRoot"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<script>
(function(){
  const API_URL_KEY = 'denpa-apps-script-url';
  const ACCESS_CODE_KEY = 'denpa-access-code';
  // このスプレッドシート連携用のURLをあらかじめ埋め込んでおくことで、
  // Claudeの会話の外でこのHTMLファイルを直接開いた人も、
  // 追加設定なしでそのまま使えるようにしています。
  // URLを変更したい場合は、この値を書き換えるか、アプリの「API設定」から再設定してください。
  const DEFAULT_API_URL = 'https://script.google.com/macros/s/AKfycbwOGMp3swafiXtbIVTqQJPn7A6-Omj57KgGm-FKZL2XGpJ01AtLk1LmA2rBBcsMl8UW/exec';
  const PHASES = ['企画','準備','当日','事後'];
  const PHASE_BADGE = {'企画':'badge-purple','準備':'badge-orange','当日':'badge-blue','事後':'badge-teal'};
  const PHASE_COLOR = {'企画':'#8348D6','準備':'#E88A00','当日':'#2F7BEE','事後':'#0E9E86'};
  const STATUS_LIST = ['未着手','進行中','完了'];
  const STATUS_BADGE = {'未着手':'badge-gray','進行中':'badge-blue','完了':'badge-teal'};

  let state = null;
  let apiUrl = null;
  let accessCode = '';
  let apiError = null;
  let toastMessage = null;
  let toastTimer = null;

  function showToast(text){
    toastMessage = text;
    renderShell();
    if(toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(()=>{ toastMessage = null; renderShell(); }, 2200);
  }
  let modalOpen = false;
  let activeTab = 'dashboard';
  let scheduleFilter = 'all';

  function uid(){ return 'id_' + Date.now().toString(36) + Math.random().toString(36).slice(2,8); }
  function esc(s){ return (s===undefined||s===null? '': String(s)).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
  function yen(n){ n = Number(n)||0; return '¥' + n.toLocaleString('ja-JP'); }
  function fmtDate(d){
    if(!d) return '未定';
    let s = String(d);
    const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
    if(m) s = m[1];
    const dt = new Date(s+'T00:00:00');
    if(isNaN(dt)) return '未定';
    return dt.toLocaleDateString('ja-JP', {year:'numeric', month:'2-digit', day:'2-digit', weekday:'short'});
  }
  function todayStr(){ return new Date().toISOString().slice(0,10); }

  function emptyState(){
    return { eventInfo:{teamName:'DENPA', name:'', date:''}, members:[], schedule:[], budget:[], survey:[] };
  }

  function normalizeData(data){
    const info = data && data.eventInfo ? data.eventInfo : {};
    return {
      eventInfo:{ teamName: info.teamName || 'DENPA', name: info.name || '', date: info.date || '' },
      members: (data && data.members) || [],
      schedule: (data && data.schedule) || [],
      budget: ((data && data.budget) || []).map(b=>({...b, budgeted:Number(b.budgeted)||0, actual:Number(b.actual)||0})),
      survey: ((data && data.survey) || []).map(r=>({...r, satisfaction:Number(r.satisfaction)||0}))
    };
  }

  // window.storage (Claude内でのみ使える永続化) が使えない環境
  // (このHTMLを単体でホスティング・保存した場合など) では、
  // 代わりにブラウザのlocalStorageを使う。どちらもダメなら諦めて
  // 都度入力してもらう。
  async function storageGet(key){
    try{
      const res = await window.storage.get(key, true);
      if(res && res.value) return res.value;
      return null;
    }catch(e){
      try{ return window.localStorage.getItem(key); }catch(e2){ return null; }
    }
  }
  async function storageSet(key, value){
    try{ await window.storage.set(key, value, true); return; }
    catch(e){ try{ window.localStorage.setItem(key, value); }catch(e2){ /* give up silently */ } }
  }

  async function getApiUrl(){
    const stored = await storageGet(API_URL_KEY);
    return stored || DEFAULT_API_URL || null;
  }
  async function setApiUrl(url){
    apiUrl = url;
    await storageSet(API_URL_KEY, url);
  }
  async function getAccessCode(){
    return (await storageGet(ACCESS_CODE_KEY)) || '';
  }
  async function setAccessCode(code){
    accessCode = code;
    await storageSet(ACCESS_CODE_KEY, code);
  }

  async function apiGet(){
    const sep = apiUrl.indexOf('?') > -1 ? '&' : '?';
    const res = await fetch(apiUrl + sep + 'token=' + encodeURIComponent(accessCode || ''));
    if(!res.ok) throw new Error('API GET failed: ' + res.status);
    const json = await res.json();
    if(!json.ok){
      if(json.error === 'unauthorized') throw new Error('unauthorized');
      throw new Error(json.error || 'API returned an error');
    }
    return json.data;
  }
  async function apiPost(entity, op, payload){
    const res = await fetch(apiUrl, {
      method:'POST',
      headers:{ 'Content-Type':'text/plain;charset=utf-8' },
      body: JSON.stringify({ entity, op, payload, token: accessCode || '' })
    });
    if(!res.ok) throw new Error('API POST failed: ' + res.status);
    const json = await res.json();
    if(!json.ok){
      if(json.error === 'unauthorized') throw new Error('unauthorized');
      throw new Error(json.error || 'API returned an error');
    }
    // the Apps Script backend already returns the full, freshly-read dataset
    // alongside the write result, so we can apply it directly instead of
    // making a second round trip with a separate GET request.
    if(json.data){ state = normalizeData(json.data); }
    return json;
  }

  async function refreshFromApi(){
    const data = await apiGet();
    state = normalizeData(data);
    apiError = null;
  }

  async function runApiAction(fn, successMessage){
    let ok = true;
    try{
      await fn();
      apiError = null;
      if(successMessage){ showToast(successMessage); }
    }catch(err){
      console.error('api action failed', err);
      if(err.message === 'unauthorized'){
        apiError = 'アクセスコードが違うか未設定です。右上の「アクセスコード」から正しいコードを入力してください。';
        alert('アクセスコードが正しくないため、データを取得・保存できませんでした。\n右上の「アクセスコード」ボタンから正しいコードを入力してください。');
      } else {
        apiError = 'スプレッドシートとの通信に失敗しました。ネットワーク状況や、Apps ScriptのURL設定をご確認ください。';
        alert('保存に失敗しました。内容は消えていないので、もう一度お試しください。\n(' + err.message + ')');
      }
      ok = false;
    }
    renderShell(); renderTab();
    return ok;
  }

  function memberName(id){ const m = state.members.find(x=>x.id===id); return m ? m.name : '未定'; }

  // ---------- MODAL ----------
  function closeModal(){ document.getElementById('modalRoot').innerHTML = ''; modalOpen = false; }

  // ---------- DATE RANGE CALENDAR PICKER ----------
  // Renders a month calendar where the user can drag across days to pick a
  // range, and drag the start/end edge of an existing range to stretch or
  // shrink it, instead of using two separate native date inputs.
  function createDateRangePicker(container, initialStart, initialEnd, onChange){
    let start = initialStart || todayStr();
    let end = (initialEnd && initialEnd >= start) ? initialEnd : start;
    let viewDate = new Date(start+'T00:00:00');
    let dragMode = null; // null | 'new' | 'start' | 'end'
    let anchorDate = null;

    function pad(n){ return String(n).padStart(2,'0'); }
    function toStr(y,m,d){ return y+'-'+pad(m+1)+'-'+pad(d); }

    function dayCellHtml(ds, dayNum, otherMonth, todays){
      let cls = 'cal-day';
      if(otherMonth) cls += ' other-month';
      if(ds === todays) cls += ' today';
      if(ds >= start && ds <= end){
        if(start===end) cls += ' range-single';
        else if(ds===start) cls += ' range-start';
        else if(ds===end) cls += ' range-end';
        else cls += ' in-range';
      }
      return '<button type="button" class="'+cls+'" data-date="'+ds+'">'+dayNum+'</button>';
    }

    function render(){
      const y = viewDate.getFullYear(), m = viewDate.getMonth();
      const first = new Date(y,m,1);
      const startWeekday = first.getDay();
      const daysInMonth = new Date(y,m+1,0).getDate();
      const daysInPrevMonth = new Date(y,m,0).getDate();
      const todays = todayStr();

      let cells = '';
      for(let i=0;i<startWeekday;i++){
        const d = daysInPrevMonth - startWeekday + 1 + i;
        const pm = m===0? 11: m-1, py = m===0? y-1: y;
        cells += dayCellHtml(toStr(py,pm,d), d, true, todays);
      }
      for(let d=1; d<=daysInMonth; d++){
        cells += dayCellHtml(toStr(y,m,d), d, false, todays);
      }
      const totalCells = startWeekday + daysInMonth;
      const trailing = (7 - (totalCells % 7)) % 7;
      for(let i=1;i<=trailing;i++){
        const nm = m===11?0:m+1, ny = m===11?y+1:y;
        cells += dayCellHtml(toStr(ny,nm,i), i, true, todays);
      }

      container.innerHTML =
        '<div class="cal-widget">'+
          '<div class="cal-header">'+
            '<button type="button" class="btn btn-sm cal-nav" data-nav="-1">‹</button>'+
            '<div style="font-weight:700;">'+y+'年 '+(m+1)+'月</div>'+
            '<button type="button" class="btn btn-sm cal-nav" data-nav="1">›</button>'+
          '</div>'+
          '<div class="cal-grid">'+
            ['日','月','火','水','木','金','土'].map(d=>'<div class="cal-dow">'+d+'</div>').join('')+
            cells+
          '</div>'+
          '<div class="cal-summary">'+(start===end ? fmtDate(start) : fmtDate(start)+' 〜 '+fmtDate(end))+
            '<span class="cal-hint">日をドラッグして期間を選択・端をつまんで伸縮</span></div>'+
        '</div>';

      container.querySelectorAll('.cal-nav').forEach(btn=>{
        btn.addEventListener('click', function(){ viewDate.setMonth(viewDate.getMonth()+Number(btn.dataset.nav)); render(); });
      });
      container.querySelectorAll('.cal-day').forEach(cell=>{
        cell.addEventListener('mousedown', onDown);
        cell.addEventListener('mouseenter', onEnter);
        cell.addEventListener('touchstart', onTouchStart, {passive:false});
        cell.addEventListener('touchmove', onTouchMove, {passive:false});
      });
    }

    function applyDrag(ds){
      if(dragMode==='new'){
        if(ds < anchorDate){ start=ds; end=anchorDate; } else { start=anchorDate; end=ds; }
      } else if(dragMode==='start'){
        if(ds>end){ start=end; end=ds; dragMode='end'; } else { start=ds; }
      } else if(dragMode==='end'){
        if(ds<start){ end=start; start=ds; dragMode='start'; } else { end=ds; }
      }
      render();
    }

    function onDown(e){
      e.preventDefault();
      const ds = e.currentTarget.dataset.date;
      if(start!==end && ds===start){ dragMode='start'; }
      else if(start!==end && ds===end){ dragMode='end'; }
      else { dragMode='new'; anchorDate=ds; start=ds; end=ds; }
      render();
      document.addEventListener('mouseup', onUp, {once:true});
    }
    function onEnter(e){
      if(!dragMode) return;
      applyDrag(e.currentTarget.dataset.date);
    }
    function onUp(){
      if(!dragMode) return;
      dragMode=null; anchorDate=null;
      onChange(start, end);
    }
    function cellFromTouch(e){
      const t = e.touches[0];
      const el = document.elementFromPoint(t.clientX, t.clientY);
      return el && el.classList && el.classList.contains('cal-day') ? el : null;
    }
    function onTouchStart(e){
      e.preventDefault();
      onDown({preventDefault(){}, currentTarget:e.currentTarget});
    }
    function onTouchMove(e){
      e.preventDefault();
      if(!dragMode) return;
      const cell = cellFromTouch(e);
      if(cell) applyDrag(cell.dataset.date);
    }
    document.addEventListener('touchend', function(){ if(dragMode) onUp(); });

    render();
    onChange(start, end);
  }

